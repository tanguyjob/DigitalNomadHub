@model List<Country>
<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                Category List
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Country" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Country
            </a>
        </div>
    </div>
    <table class="table table-bordered table-striped">       
        <thead>
            <tr>
                <th>Country Name</th>    
            </tr>
        </thead>
        <tbody>
            @foreach(var obj in Model.OrderBy(x=>x.Name))
            {
                <tr>
                    <td>@obj.Name</td>
                </tr>
            }
        </tbody>
    </table>
</div>